---
// Create delays
const delay1 = `-${Math.random() * 20}s`;
const delay2 = `-${Math.random() * 10}s`;
const delay3 = `-${Math.random() * 15}s`;
const delay4 = `-${Math.random() * 10}s`;

// Scale differently
const scale = (1.3 + Math.random() * 0.4).toFixed(2);
---

<div
  class="orb-bg"
  style={`
    --d1: ${delay1};
    --d2: ${delay2};
    --d3: ${delay3};
    --d4: ${delay4};
    transform: scale(${scale});
  `}
>
</div>

<style>
  .orb-bg {
    width: 100%;
    height: 100%;
    background:
      radial-gradient(
        ellipse at 20% 50%,
        var(--color-primary) 0%,
        transparent 50%
      ),
      radial-gradient(
        ellipse at 80% 20%,
        var(--color-secondary) 0%,
        transparent 45%
      ),
      radial-gradient(
        ellipse at 60% 80%,
        var(--color-primary) 0%,
        transparent 55%
      ),
      radial-gradient(
        ellipse at 10% 10%,
        var(--color-secondary) 0%,
        transparent 40%
      ),
      linear-gradient(
        -45deg,
        var(--color-primary),
        var(--color-secondary),
        #23a6d5,
        #23d5ab
      );
    background-size:
      200% 200%,
      180% 180%,
      220% 220%,
      160% 160%,
      100% 100%;
    animation:
      layer1 6s ease var(--d1) infinite alternate,
      layer2 8s ease var(--d2) infinite alternate,
      layer3 10s ease var(--d3) infinite alternate,
      layer4 4s ease var(--d4) infinite alternate;
  }

  @keyframes layer1 {
    0% {
      background-position:
        0% 50%,
        100% 0%,
        50% 100%,
        0% 0%,
        0% 0%;
    }
    100% {
      background-position:
        100% 50%,
        0% 100%,
        100% 0%,
        100% 100%,
        0% 0%;
    }
  }

  @keyframes layer2 {
    0% {
      background-position:
        100% 50%,
        0% 100%,
        100% 0%,
        100% 100%,
        0% 0%;
    }
    100% {
      background-position:
        0% 0%,
        100% 50%,
        0% 100%,
        50% 0%,
        0% 0%;
    }
  }

  @keyframes layer3 {
    0% {
      background-position:
        50% 0%,
        50% 100%,
        0% 50%,
        100% 50%,
        0% 0%;
    }
    100% {
      background-position:
        0% 100%,
        100% 0%,
        100% 100%,
        0% 0%,
        0% 0%;
    }
  }

  @keyframes layer4 {
    0% {
      background-position:
        0% 0%,
        100% 100%,
        50% 50%,
        0% 100%,
        0% 0%;
    }
    100% {
      background-position:
        100% 100%,
        0% 0%,
        100% 50%,
        100% 0%,
        0% 0%;
    }
  }
</style>
