---
import Tag from './Tag.astro';
import GradientOrbs from './GradientOrbs.astro';

interface Props {
  project: {
    title: string;
    description: string;
    url?: string;
    repo?: string;
    tags: string[];
    featured: boolean;
    date: Date;
    coverImage?: string;
  };
  itemNumber?: number;
  href?: string;
}

const { project, itemNumber, href } = Astro.props;

const MAX_TAGS = 3;
const visibleTags = project.tags.slice(0, MAX_TAGS);
const remainingTagsCount = project.tags.length - MAX_TAGS;
---

<div
  class="w-full flex flex-col border-2 border-border rounded-xl bg-bg-secondary"
>
  <div class="w-full aspect-video p-2">
    <div class="relative flex-1 h-full rounded-t-xl overflow-hidden">
      <GradientOrbs />
      <div class="absolute inset-0 pointer-events-none">
        <div class="flex flex-row justify-between items-center select-none">
          {
            itemNumber && (
              <span class="text-text/50 m-4 text-6xl font-sans font-extrabold">
                {itemNumber}.
              </span>
            )
          }
          {
            project.featured && (
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                class="size-10 text-text/50 m-4"
              >
                <path
                  fill-rule="evenodd"
                  d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.006 5.404.434c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.434 2.082-5.005Z"
                  clip-rule="evenodd"
                />
              </svg>
            )
          }
        </div>
      </div>
    </div>
  </div>
  <div class="flex flex-col flex-1 p-4 border-t-2 border-border">
    <div class="flex-1">
      <h3 class="text-text text-2xl mb-2">{project.title}</h3>
      <p class="text-text-secondary font-sans mb-2">
        {project.description}
      </p>
    </div>
    <div class="flex flex-row justify-between gap-4 items-center">
      <div
        class="flex-1 min-w-0 flex flex-row gap-2 overflow-hidden items-center py-1"
      >
        {visibleTags.map((tag: string) => <Tag text={tag} />)}

        {
          remainingTagsCount > 0 && (
            <span class="text-text-secondary text-lg font-sans">
              +{remainingTagsCount}
            </span>
          )
        }
      </div>
      <a
        href={href}
        class="shrink-0 py-2 px-4 rounded bg-primary hover:bg-secondary transition-colors select-none"
      >
        <div class="flex items-center gap-2 text-text">
          <span>View Project</span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            class="size-4"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"></path>
          </svg>
        </div>
      </a>
    </div>
  </div>
</div>
